model Model
	culture: es-ES
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-ES
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup dimensiones

	annotation PBI_QueryGroupOrder = 0

queryGroup hechos_facts

	annotation PBI_QueryGroupOrder = 1

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["fact_inventarios","fact_movimientos_almacen","dim_productos","dim_almacen"]

ref table fact_inventarios
ref table fact_movimientos_almacen
ref table dim_productos
ref table dim_almacen
ref table dim_time

ref cultureInfo es-ES

